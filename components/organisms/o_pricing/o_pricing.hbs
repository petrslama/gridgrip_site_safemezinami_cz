<section class="o_pricing grid"
	{{#if section_id}}
	 id="{{section_id}}"
	{{/if}}>
	{{> m_section_title }}
	{{#each plans}}
	<div class="plan col-4{{#if featured}} plan--featured{{/if}}">
		<div class="icon">
			{{> a_icon }}
		</div>
		{{#if label}}
		<p class="label">{{label}}</p>
		{{/if}}
		{{#if title}}
		<h3 class="title">{{title}}</h3>
		{{/if}}
		{{#if price}}
		<div class="price">
			{{price}}
			{{#if currency}}
			<span>{{currency}}</span>
			{{/if}}
		</div>
		{{/if}}
		{{#if per}}
		<p class="per">{{per}}</p>
		{{/if}}
		{{#if note}}
		<hr class="divider">
		<p class="note">{{{note}}}</p>
		{{/if}}
	</div>
	{{/each}}
	{{#if footer_note}}
	<p class="footer_note col-12">{{{footer_note}}}</p>
	{{/if}}
</section>
